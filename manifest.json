{
  "manifest_version": 3,
  "name": "whaaaa",
  "version": "1.0.4",
  "description": "マウスを合わせた要素の色・ボーダー・フォント・余白・サイズを表示。クリックでコピー。",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "whaaaa を切り替え",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
